# Third-party tools (large binaries, installed locally)
tools/

# VS Code workspace (user-specific)
*.code-workspace

# UE4 build artifacts (regenerated by UBT)
project/Binaries/
project/Intermediate/
project/Saved/
project/DerivedDataCache/
project/.vs/
project/*.sln
project/*.vcxproj*

# Content (imported separately via JsonAsAsset in Phase 3)
project/Content/
